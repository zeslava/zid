# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=zid
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Database URL for migrations (sqlx-cli)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/zid

# Redis Configuration
REDIS_URL=redis://127.0.0.1:6380

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=5555

# Trusted Domains (comma-separated)
TRUSTED_DOMAINS=localhost,127.0.0.1,*.local.dev,*.local,*.lan

# OIDC/OAuth 2.0 (по умолчанию включён; при отсутствии конфига/ключей — запуск без OIDC)
# OIDC_ENABLED=true
# OIDC_ISSUER=http://localhost:5555
# OIDC_CLIENTS_FILE=oidc_clients.yaml
# OIDC_JWT_PRIVATE_KEY=oidc_jwt_private.pem
# OIDC_JWT_PUBLIC_KEY=oidc_jwt_public.pem
